# ===========================================
# Evergreen Vault MCP Server — Environment
# ===========================================

# Required: same DATABASE_URL as the Next.js app
DATABASE_URL=postgresql://vault:vault_secret@192.168.4.240:5432/evergreen_vault

# Ollama — MUST be localhost (loopback only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Transport: "stdio" (default, for Claude Code/Desktop) or "http" (for remote access)
TRANSPORT=stdio

# HTTP transport settings (only used when TRANSPORT=http)
MCP_PORT=8020
VAULT_API_KEY=change-me-to-a-random-string
