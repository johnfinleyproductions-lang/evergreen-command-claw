# ===========================================
# Evergreen Vault — Environment Configuration
# ===========================================

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://vault:vault_secret@192.168.4.240:5432/evergreen_vault

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=http://192.168.4.240:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evergreen-vault
MINIO_PUBLIC_URL=http://192.168.4.240:9000/evergreen-vault

# --- Auth (single-user HMAC session) ---
AUTH_SECRET=change-me-to-a-random-64-char-hex-string
AUTH_PASSWORD=change-me

# --- API Key (for REST API + MCP HTTP access) ---
VAULT_API_KEY=change-me-to-a-random-string

# --- Ollama (local AI — primary) ---
OLLAMA_BASE_URL=http://192.168.4.240:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen3.5:9b

# --- OpenAI (optional cloud fallback) ---
OPENAI_API_KEY=

# --- Embedding config ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768
