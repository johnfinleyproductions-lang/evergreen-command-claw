# ===========================================
# Evergreen Command — Environment Configuration
# ===========================================

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://command:command_secret@localhost:5432/evergreen_command

# --- MinIO (S3-compatible object storage for task artifacts) ---
# NOTE: ports 9010/9011 (not 9000/9001) because the old
# evergreen-vault-minio container is still running on 9000/9001.
MINIO_ENDPOINT=http://localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evergreen-command
MINIO_PUBLIC_URL=http://localhost:9010/evergreen-command

# --- Auth (single-user HMAC session) ---
AUTH_SECRET=change-me-to-a-random-64-char-hex-string
AUTH_PASSWORD=change-me

# --- API Key (for REST API + MCP HTTP access) ---
COMMAND_API_KEY=change-me-to-a-random-string

# ===========================================
# Inference endpoints
# ===========================================

# --- llama.cpp (PRIMARY — heavy-lifting 120 B model on the Framestation) ---
# The Vercel AI SDK uses these to route all heavy completions locally.
# Launch llama-server via: tmux new -d -s llama-server "... --port 8081"
# Remember to run `sudo nvidia-smi -pm 1 && sudo nvidia-smi -lgc 1933,1933` FIRST.
LLAMA_CPP_BASE_URL=http://localhost:8081/v1
LLAMA_CPP_MODEL=nvidia_Nemotron-3-Super-120B-A12B-Q4_K_M-00001-of-00003.gguf
LLAMA_CPP_API_KEY=not-needed-but-sdk-requires-a-value

# The Vercel AI SDK expects OpenAI-compatible env vars. Point them at llama.cpp.
OPENAI_BASE_URL=http://localhost:8081/v1
OPENAI_API_KEY=not-needed-but-sdk-requires-a-value

# --- Ollama (SECONDARY — embeddings + small-model fallback) ---
# Kept for nomic-embed-text embeddings and fast fallback when llama.cpp is down.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_FALLBACK_CHAT_MODEL=qwen3.5:9b

# --- Embedding config ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768

# ===========================================
# GPU safety (for reference — actual lock happens via nvidia-smi before launch)
# ===========================================
# GPU_CLOCK_LOCK_MHZ=1933
# RULE: Never change clocks mid-inference. Always kill llama-server first.
